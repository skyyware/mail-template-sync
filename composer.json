{
  "name": "skyyware/mail-template-sync",
  "type": "shopware-platform-plugin",
  "description": "Synchronize Shopware mail templates with the filesystem.",
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "shopware/core": "~6.6.0 || ~6.7.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.68",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Skyyware\\SkyyMailTemplateSync\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Skyyware\\SkyyMailTemplateSync\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/runtime": true
    },
    "platform": {
      "php": "8.2.0"
    }
  },
  "extra": {
    "shopware-plugin-class": "Skyyware\\SkyyMailTemplateSync\\SkyyMailTemplateSync",
    "plugin-icon": "src/Resources/config/plugin.png",
    "label": {
      "en-GB": "Skyy Mail Template Sync",
      "de-DE": "Skyy Mail Template Sync"
    },
    "manufacturerLink": {
      "en-GB": "https://www.skyyware.com/",
      "de-DE": "https://www.skyyware.com/"
    },
    "supportLink": {
      "en-GB": "https://www.skyyware.com/contact/",
      "de-DE": "https://www.skyyware.com/contact/"
    }
  }
}
