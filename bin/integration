#!/usr/bin/env bash

set -euo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)
: "${SHOPWARE_PROJECT_ROOT:?Set SHOPWARE_PROJECT_ROOT to an installed Shopware project.}"
: "${DATABASE_URL:?Set DATABASE_URL to an isolated disposable database.}"

if [[ ! -d "$SHOPWARE_PROJECT_ROOT" ]]; then
    printf 'SHOPWARE_PROJECT_ROOT is not a directory: %s\n' "$SHOPWARE_PROJECT_ROOT" >&2
    exit 1
fi

SHOPWARE_PROJECT_ROOT=$(cd "$SHOPWARE_PROJECT_ROOT" && pwd -P)
PHP_BINARY=${SKYY_PHP_BINARY:-php}
PHP_MEMORY_LIMIT=${PHP_MEMORY_LIMIT:-1G}
PHPUNIT=${SKYY_PHPUNIT_BINARY:-"$SHOPWARE_PROJECT_ROOT/vendor/bin/phpunit"}
PLUGIN_PARENT="$SHOPWARE_PROJECT_ROOT/custom/plugins"
PLUGIN_LINK="$PLUGIN_PARENT/SkyyMailTemplateSync"
PACKAGE_ARCHIVE="$ROOT/build/SkyyMailTemplateSync-0.1.1.zip"
STAGING=$(mktemp -d)
STAGING=$(cd "$STAGING" && pwd -P)
PLUGIN_SOURCE="$STAGING/SkyyMailTemplateSync"

if [[ ! -f "$PHPUNIT" ]]; then
    printf 'Integration PHPUnit executable not found: %s\n' "$PHPUNIT" >&2
    exit 1
fi

created_custom=0
created_plugins=0
created_link=0

cleanup() {
    local status=$?
    local target=''

    trap - EXIT INT TERM HUP

    if [[ "$created_link" -eq 1 ]]; then
        if [[ -L "$PLUGIN_LINK" ]]; then
            target=$(cd "$PLUGIN_LINK" 2>/dev/null && pwd -P) || true
            if [[ "$target" == "$PLUGIN_SOURCE" ]]; then
                rm -f "$PLUGIN_LINK"
            else
                printf 'Refusing to remove changed integration symlink: %s\n' "$PLUGIN_LINK" >&2
                status=1
            fi
        else
            printf 'Refusing to remove integration path because it is no longer our symlink: %s\n' "$PLUGIN_LINK" >&2
            status=1
        fi
    fi

    if [[ "$created_plugins" -eq 1 ]]; then
        rmdir "$PLUGIN_PARENT" 2>/dev/null || true
    fi
    if [[ "$created_custom" -eq 1 ]]; then
        rmdir "$SHOPWARE_PROJECT_ROOT/custom" 2>/dev/null || true
    fi

    rm -rf "$STAGING"

    exit "$status"
}

trap cleanup EXIT
trap 'exit 130' INT
trap 'exit 143' TERM
trap 'exit 129' HUP

"$ROOT/bin/package"
unzip -q "$PACKAGE_ARCHIVE" -d "$STAGING"
if [[ ! -f "$PLUGIN_SOURCE/src/SkyyMailTemplateSync.php" ]]; then
    printf 'Packaged plugin entry point not found: %s\n' "$PLUGIN_SOURCE/src/SkyyMailTemplateSync.php" >&2
    exit 1
fi

if [[ ! -e "$SHOPWARE_PROJECT_ROOT/custom" ]]; then
    mkdir "$SHOPWARE_PROJECT_ROOT/custom"
    created_custom=1
fi
if [[ ! -e "$PLUGIN_PARENT" ]]; then
    mkdir "$PLUGIN_PARENT"
    created_plugins=1
fi

if [[ -e "$PLUGIN_LINK" || -L "$PLUGIN_LINK" ]]; then
    printf 'Plugin discovery path is already occupied: %s\n' "$PLUGIN_LINK" >&2
    exit 1
else
    ln -s "$PLUGIN_SOURCE" "$PLUGIN_LINK"
    created_link=1
fi

export SHOPWARE_PROJECT_ROOT
export SKYY_PLUGIN_RUNTIME_ROOT="$PLUGIN_SOURCE"

"$PHP_BINARY" \
    -d "memory_limit=$PHP_MEMORY_LIMIT" \
    "$PHPUNIT" \
    -c "$ROOT/phpunit.integration.xml.dist"
