<?xml version="1.0" encoding="UTF-8" ?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">
    <card>
        <title>Mail template sync</title>
        <title lang="de-DE">Mail-Template-Synchronisierung</title>

        <input-field type="text">
            <name>storageDirectory</name>
            <label>Storage directory</label>
            <label lang="de-DE">Speicherverzeichnis</label>
            <defaultValue>custom/mail-templates</defaultValue>
        </input-field>

        <input-field type="int">
            <name>backupRetentionDays</name>
            <label>Backup retention days</label>
            <label lang="de-DE">Aufbewahrungsdauer von Sicherungen in Tagen</label>
            <defaultValue>365</defaultValue>
            <min>0</min>
        </input-field>
    </card>
</config>
